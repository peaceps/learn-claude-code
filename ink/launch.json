{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch langgraphjs",
            "cwd": "${workspaceFolder}/langgraphjs",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "${workspaceFolder}/langgraphjs/node_modules/tsx/dist/cli.mjs"
            ],
            "program": "${workspaceFolder}/langgraphjs/main.ts",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch ink",
            "cwd": "${workspaceFolder}/ink",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "${workspaceFolder}/langgraphjs/node_modules/tsx/dist/cli.mjs"
            ],
            "program": "${workspaceFolder}/ink/ui/cli.tsx",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal"
        }
    ]
}